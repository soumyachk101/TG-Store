# --- Telegram ---
# From @BotFather
BOT_TOKEN=
# Private channel id (negative, e.g. -100xxxxxxxxxx). Bot must be admin.
CHAT_ID=

# --- Database ---
# Defaults to local docker-compose Postgres on port 5433 (host 5432 is taken on this machine)
DATABASE_URL=postgresql+asyncpg://tgstore:tgstore@localhost:5433/tgstore
# Used by Alembic (sync URL) — derive if blank
DATABASE_URL_SYNC=postgresql+psycopg2://tgstore:tgstore@localhost:5433/tgstore

# --- Auth ---
# Random 32+ byte string. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-real-secret-please-32-bytes-min
JWT_EXPIRE_HOURS=24
# Single-user credentials (per Docs/PRD.md §3.6)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- CORS ---
# Comma-separated list of allowed origins. Include Vercel URL in prod.
ALLOWED_ORIGINS=http://localhost:3000

# --- Upload limits (bytes). Default 2 GB matches Telegram limit. ---
MAX_UPLOAD_BYTES=2147483648
