# Backend API base URL. NO trailing slash.
// In dev: http://localhost:8000
// In prod: set to Railway/Render URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth (Auth.js v5) — REQUIRED. /api/auth/* will return 500 without these.
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# In dev: http://localhost:3000  In prod: https://your-app.vercel.app
AUTH_URL=http://localhost:3000

# Firebase Client SDK Configuration (Required for client-side Auth integration)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
